# Copiar para .env e preencher. Não commitar .env
# ENVIRONMENT: dev | uat | prod | poc (alinhado com template.yaml e scripts SSM)
ENVIRONMENT=dev
# Com `make deploy` / `sync-rag-context`: STACK_NAME = {ENVIRONMENT}-nvidia-demo e o SAM recebe Environment= igual.
AWS_REGION=sa-east-1
# Opcional: o Makefile exporta AWS_PROFILE / AWS_REGION para sam e aws (mesmos nomes que o CLI).
# AWS_PROFILE=meu-perfil

# EC2 semantic-router (SAM): sobrepõem SemanticRouterVpcId / SemanticRouterPublicSubnetId do samconfig.
# A subnet deve ser pública (rota 0.0.0.0/0 → Internet Gateway) para o EIP e apt funcionarem.
# SEMANTIC_ROUTER_VPC_ID=vpc-0abc123def456789a
# SEMANTIC_ROUTER_PUBLIC_SUBNET_ID=subnet-0abc123def456789a

# WhatsApp / Meta Cloud API — webhook (SecureString via `make ssm-secrets` → scripts/ssm_put_secrets_from_env.py)
# App Secret (assinatura X-Hub-Signature-256), token de verificação do webhook (GET hub.verify_token), token da API Graph.
META_WEBHOOK_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=
META_WEBHOOK_WHATSAPP_API_TOKEN=

# WhatsApp Business phone_number_id (ID numérico Meta no URL Graph …/{id}/messages — emissor das respostas API).
# String SSM meta_phone_number_id via scripts/ssm_put_string_params_from_env.py (make deploy).
META_PHONE_NUMBER_ID=

# EC2 semantic-router (SecureString via scripts/ssm_put_secrets_from_env.py ou sync_smart_router_key.py)
SMART_ROUTER_KEY=

# LLM principal (LiteLLM: OpenAI, Azure OpenAI, endpoint OpenAI-compatible, etc.)
MAIN_LLM_KEY=
# Strings (scripts/ssm_put_string_params_from_env.py)
# MAIN_LLM_API: ex. https://api.openai.com/v1 | https://RECURSO.openai.azure.com | http://HOST:8000/v1
# MAIN_LLM_MODEL: nome LiteLLM — ex. gpt-4o-mini, azure/gpt-4o-mini, openai/nome-no-servidor
# Azure: se MAIN_LLM_API_VERSION vazio, usa-se 2024-08-01-preview por defeito.
MAIN_LLM_API=https://api.openai.com/v1
MAIN_LLM_MODEL=gpt-4o-mini
MAIN_LLM_TIMEOUT_S=120
# Opcional — api-version (Azure); outros providers se aplicável.
MAIN_LLM_API_VERSION=
